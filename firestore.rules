rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Default Deny Layout)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for Auth State and Role Verification
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid == 'admin_master';
    }

    function isOwner(existingData) {
      return isSignedIn() && existingData.ownerId == request.auth.uid;
    }

    function isNewOwner(incomingData) {
      return isSignedIn() && incomingData.ownerId == request.auth.uid;
    }

    // 1. Barbers Collection
    match /barbers/{barberId} {
      // Admins (admin_master) can read/write everything. Individual barbers can only read their own license/profile document.
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == barberId);
      allow write: if isAdmin();
    }

    // 2. Clients Collection
    match /clients/{clientId} {
      // Admins or the owner of the client record can read or write.
      allow read: if isAdmin() || isOwner(resource.data);
      allow create: if isAdmin() || isNewOwner(request.resource.data);
      allow update, delete: if isAdmin() || isOwner(resource.data);
    }

    // 3. Cuts subcollection
    match /clients/{clientId}/cuts/{cutId} {
      // Owner-based access to the cut history documents.
      allow read: if isAdmin() || isOwner(resource.data);
      allow create: if isAdmin() || isNewOwner(request.resource.data);
      allow update, delete: if isAdmin() || isOwner(resource.data);
    }

    // 4. Services Collection
    match /services/{serviceId} {
      // Catalog of services offered. Isolated by barber.
      allow read: if isAdmin() || isOwner(resource.data);
      allow create: if isAdmin() || isNewOwner(request.resource.data);
      allow update, delete: if isAdmin() || isOwner(resource.data);
    }
  }
}
