rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Default Deny Layout)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for Auth State and Role Verification
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'admin_master' ||
        request.auth.token.email == 'jamersonferramentas@gmail.com' ||
        exists(/databases/$(database)/documents/admin_sessions/$(request.auth.uid))
      );
    }

    function isOwner(existingData) {
      return isSignedIn() && (
        existingData.ownerId == request.auth.uid || 
        (existingData.ownerId != null && 
         exists(/databases/$(database)/documents/barbers/$(existingData.ownerId)) &&
         get(/databases/$(database)/documents/barbers/$(existingData.ownerId)).data.firebaseUid == request.auth.uid)
      );
    }

    function isNewOwner(incomingData) {
      return isSignedIn() && (
        incomingData.ownerId == request.auth.uid || 
        (incomingData.ownerId != null && 
         exists(/databases/$(database)/documents/barbers/$(incomingData.ownerId)) &&
         get(/databases/$(database)/documents/barbers/$(incomingData.ownerId)).data.firebaseUid == request.auth.uid)
      );
    }

    // 1. Barbers Collection
    match /barbers/{barberId} {
      // Anyone signed in can read (required for scheduling and login verification)
      allow read: if isSignedIn();
      allow create: if isAdmin();
      // Allow update for admin or a safe self-updating of the active anonymous firebaseUid during verification
      allow update: if isAdmin() || (
        isSignedIn() && 
        request.resource.data.username == resource.data.username && 
        request.resource.data.password == resource.data.password &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['firebaseUid'])
      );
      allow delete: if isAdmin();
    }

    // 2. Clients Collection
    match /clients/{clientId} {
      // Admins, the owner, or the client themselves (matched by logical id or active firebaseUid) can read/write
      allow read: if isAdmin() || 
                    isOwner(resource.data) || 
                    (isSignedIn() && (clientId == request.auth.uid || resource.data.firebaseUid == request.auth.uid));
      
      allow create: if isAdmin() || isNewOwner(request.resource.data);
      
      allow update: if isAdmin() || 
                    isOwner(resource.data) || 
                    (isSignedIn() && (clientId == request.auth.uid || resource.data.firebaseUid == request.auth.uid)) ||
                    (
                      isSignedIn() && 
                      request.resource.data.username == resource.data.username && 
                      request.resource.data.password == resource.data.password &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['firebaseUid'])
                    );
      allow delete: if isAdmin();
    }

    // 3. Cuts subcollection
    match /clients/{clientId}/cuts/{cutId} {
      // Owner-based access to the cut history documents.
      allow read: if isAdmin() || isOwner(resource.data);
      allow create: if isAdmin() || isNewOwner(request.resource.data);
      allow update, delete: if isAdmin() || isOwner(resource.data);
    }

    // 4. Services Collection
    match /services/{serviceId} {
      // Catalog of services offered. Isolated by barber.
      allow read: if isAdmin() || isOwner(resource.data);
      allow create: if isAdmin() || isNewOwner(request.resource.data);
      allow update, delete: if isAdmin() || isOwner(resource.data);
    }

    // 5. Admin Sessions (Iframe preview bypass credentials registration)
    match /admin_sessions/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create, update: if isSignedIn() && request.auth.uid == uid && request.resource.data.secret == 'admin123';
      allow delete: if isSignedIn() && request.auth.uid == uid;
    }
  }
}
