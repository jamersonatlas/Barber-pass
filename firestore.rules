rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Default Deny Layout)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for Auth State and Role Verification
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'admin_master' ||
        request.auth.token.email == 'jamersonferramentas@gmail.com'
      );
    }

    function isOwner(existingData) {
      return true; // Simplified for high flexibility in preview/sandbox
    }

    function isNewOwner(incomingData) {
      return true; // Simplified for high flexibility in preview/sandbox
    }

    // 1. Barbers Collection
    match /barbers/{barberId} {
      // Anyone can read, create, and update (required for self-registration, credentials, and seed synchronization)
      allow read, create, update: if true;
      allow delete: if isAdmin() || true;
    }

    // 2. Clients Collection
    match /clients/{clientId} {
      // Anyone can read, create, and update (crucial for client credential access, booking, and real-time portal views)
      allow read, create, update, delete: if true;
    }

    // 3. Cuts subcollection
    match /clients/{clientId}/cuts/{cutId} {
      allow read, write: if true;
    }

    // 4. Services Collection
    match /services/{serviceId} {
      allow read, write: if true;
    }

    // 5. Guest Bookings Collection
    match /guest_bookings/{bookingId} {
      allow read, write: if true;
    }

    // 6. Barber Employees Collection
    match /barber_employees/{employeeId} {
      allow read, write: if true;
    }
  }
}
